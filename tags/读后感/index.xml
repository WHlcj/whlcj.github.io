    <item>
      <title>《仿造品和绚丽多彩的灰》读后感</title>
      <link>https://whlcj.github.io/posts/%E4%BB%BF%E9%80%A0%E5%93%81%E5%92%8C%E7%BB%9A%E4%B8%BD%E5%A4%9A%E5%BD%A9%E7%9A%84%E7%81%B0%E8%AF%BB%E5%90%8E%E6%84%9F/</link>
